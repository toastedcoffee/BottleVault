# Database password (required)
DB_PASSWORD=your-secure-password-here

# JWT Secret — must be at least 32 characters (required)
# Generate one with: openssl rand -base64 64
JWT_SECRET=your-secure-jwt-secret-at-least-32-characters-long

# Registration (set to false after creating your account)
REGISTRATION_ENABLED=true

# Port to expose the web UI on (default: 80)
# PORT=80

# Enable Swagger API docs (default: false, only enable for development)
# SWAGGER_ENABLED=true

# Cloudflare Tunnel (required for external access)
# Create at: https://one.dash.cloudflare.com → Networks → Tunnels
# TUNNEL_TOKEN=your-tunnel-token

# Comma-separated allowed origins for CORS (e.g. https://cellar.bottlevault.app)
# Only needed when using Cloudflare Tunnel or custom domain.
# Multiple: ALLOWED_ORIGINS=https://cellar.bottlevault.app,https://bottlevault.app
# ALLOWED_ORIGINS=https://cellar.bottlevault.app
